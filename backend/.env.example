# ─────────────────────────────────────────────────────────────
# Configuración del servidor
# ─────────────────────────────────────────────────────────────
# Puerto donde escucha la API
PORT=3001

# Origen del frontend (para CORS). Vite usa 5173 por defecto.
FRONTEND_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Conexión a MySQL — BD: seg_egresado_bolsa
# Usuario definido en Database/Usuarios.sql (rol_admin, GRANT ALL)
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin_general
DB_PASSWORD=Admin123*
DB_NAME=seg_egresado_bolsa

# Cantidad de conexiones del pool
DB_CONNECTION_LIMIT=10

# ─────────────────────────────────────────────────────────────
# JWT (Fase 1 — autenticación)
# En .env: pega aquí un JWT_SECRET aleatorio (NO commitear el valor real).
# Genéralo con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secret-aleatorio
JWT_EXPIRES_IN=8h
